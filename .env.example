# Colmeia API Configuration
# Copy this file to .env and fill in your credentials

# Social Network ID (from Colmeia dashboard > Communication > API > Tokens)
COLMEIA_SOCIAL_NETWORK_ID=your_social_network_id_here

# API Key / Authorization token (from Colmeia dashboard > Communication > API > Tokens)
COLMEIA_API_KEY=your_api_key_here

# Token ID for refreshing auth tokens
COLMEIA_TOKEN_ID=your_token_id_here

# Your Colmeia account email
COLMEIA_EMAIL=your_email@domain.com

# Your Colmeia account password (plain text - will be SHA256 hashed before sending)
COLMEIA_PASSWORD=245f000c261b6e2695c3d6f2b9405a63b652cf22d6ef0bc39e1351be752ac052
